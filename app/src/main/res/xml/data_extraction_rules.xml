<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for Android 12+ (API 31+).
  Governs cloud backup and device-to-device transfers separately.

  VPN profiles are stored in app-private internal storage.
  They contain credentials (server address, certificates) — exclude from backup
  to prevent credentials from leaking via cloud backup or device transfers.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all app data from cloud backup — profiles contain server configs. -->
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude profiles from device-to-device transfers — user should re-import. -->
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
